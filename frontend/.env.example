# ─── Clerk ───────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ─── Database ────────────────────────────────────────────
# Use the POOLED connection URL from Neon (not the direct URL)
DATABASE_URL=

# ─── App ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Google OAuth (Phase 2 UI / Phase 3 backend) ─────────
# Create credentials at console.cloud.google.com
# Enable: Gmail API, Google Calendar API
# Add authorized redirect URI: {APP_URL}/api/gmail/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/gmail/callback

# ─── AI + Worker (Phase 3) ───────────────────────────────
# GEMINI_API_KEY=
# ENCRYPTION_KEY=        # 32-byte hex string for AES-256 token encryption
# CRON_SECRET=           # Random secret to protect the cron endpoint
